# AMA environment variables
# API server
AMA_DBT_PROJECT_DIR=dbt_project
AMA_OUTPUT_DIR=dbt_project/models
AMA_CHECKPOINT_DIR=dbt_project/target/checkpoints
AMA_OPENAI_API_KEY=           # required for AI features

# Frontend (copy to frontend/.env.local for local dev)
VITE_AMA_API_BASE=http://localhost:8000
VITE_DEFAULT_REPORT_PATH=sample_data/kfar_supply/kfar_report.json     # leave empty to use default chaos dataset

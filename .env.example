# Local SQL Server (container or local instance)
MSSQL_CONNECTION_STRING=DRIVER={ODBC Driver 18 for SQL Server};SERVER=localhost,1433;DATABASE=kfar_supply;UID=sa;PWD=YourStrong!Pass123;Encrypt=no;TrustServerCertificate=yes;

# ── API Server & Directories ──────────────────────────────────
AMA_DBT_PROJECT_DIR=dbt_project
AMA_OUTPUT_DIR=dbt_project/models
AMA_CHECKPOINT_DIR=dbt_project/target/checkpoints
AMA_OPENAI_API_KEY=

# ── Frontend Configuration ────────────────────────────────────
VITE_AMA_API_BASE=http://localhost:8000
VITE_DEFAULT_REPORT_PATH=sample_data/kfar_supply/kfar_report.json

# ── Schema Provider Mode ──────────────────────────────────────
AMA_SCHEMA_MODE=sqlserver

# ── Live DB Connection ────────────────────────────────────────
AMA_DB_CONNECTION_STRING=DRIVER={ODBC Driver 18 for SQL Server};SERVER=localhost,1433;DATABASE=kfar_supply;UID=sa;PWD=YourStrong!Pass123;Encrypt=no;TrustServerCertificate=yes;

# ── Discovery & Logs ──────────────────────────────────────────
AMA_MANIFEST_PATH=sample_data/kfar_supply/ddl/kfar_manifest.json
AMA_SQL_LOGS_GLOB=sample_data/kfar_supply/sql_logs/*.jsonl
AMA_DISCOVERY_MERGE_ALL=true

# ── Security & Timeouts ───────────────────────────────────────
AMA_DB_TIMEOUT=30
AMA_ENCRYPTION_KEY=
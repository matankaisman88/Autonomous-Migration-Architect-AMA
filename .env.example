# AMA environment variables
# API server
AMA_DBT_PROJECT_DIR=dbt_project
AMA_OUTPUT_DIR=dbt_project/models
AMA_CHECKPOINT_DIR=dbt_project/target/checkpoints
AMA_OPENAI_API_KEY=           # required for AI features

# Frontend (copy to frontend/.env.local for local dev)
VITE_AMA_API_BASE=http://localhost:8000
VITE_DEFAULT_REPORT_PATH=sample_data/kfar_supply/kfar_report.json     # leave empty to use default chaos dataset

AMA_DDL_MANIFEST_PATH=chaos_data/ddl/extreme_chaos_manifest.json
AMA_SQL_LOGS_GLOB=chaos_data/sql_logs/extreme_oracle.jsonl
AMA_DISCOVERY_MERGE_ALL=true

# ── Schema Provider Mode ──────────────────────────────────────
# Options: file | postgres | oracle
AMA_SCHEMA_MODE=file

# ── Live DB Connection ────────────────────────────────────────
# Required when AMA_SCHEMA_MODE != "file"
# Postgres:  postgresql://user:password@host:5432/dbname
# Oracle:    user/password@host:1521/ORCL
AMA_DB_CONNECTION_STRING=

# Set to "true" if AMA_DB_CONNECTION_STRING is Fernet-encrypted
# AMA_DB_ENCRYPTED=false

# ── Encryption Key ────────────────────────────────────────────
# Generate with: python -c "from ama.mcp.encryption import generate_key; print(generate_key())"
# Never commit this value.
AMA_ENCRYPTION_KEY=

# ── Timeouts ──────────────────────────────────────────────────
AMA_DB_TIMEOUT=10

# ── File Mode Paths (used when AMA_SCHEMA_MODE=file) ─────────
AMA_MANIFEST_PATH=ddl_manifest.json

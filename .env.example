# Local SQL Server (container or local instance)
MSSQL_CONNECTION_STRING=DRIVER={ODBC Driver 18 for SQL Server};SERVER=<SQLSERVER_HOST_OR_IP>;DATABASE=kfar_supply;UID=sa;PWD=<YOUR_SQL_PASSWORD>;Encrypt=yes;TrustServerCertificate=yes;

# API Server & Directories
AMA_DBT_PROJECT_DIR=dbt_project
AMA_OUTPUT_DIR=dbt_project/models
AMA_CHECKPOINT_DIR=dbt_project/target/checkpoints
AMA_OPENAI_API_KEY=<YOUR_OPENAI_API_KEY>

# Frontend Configuration
VITE_AMA_API_BASE=http://localhost:8000
VITE_DEFAULT_REPORT_PATH=sample_data/kfar_supply/kfar_report.json

# Schema Provider Mode
AMA_SCHEMA_MODE=sqlserver

# Live DB Connection
AMA_DB_CONNECTION_STRING=DRIVER={ODBC Driver 18 for SQL Server};SERVER=<SQLSERVER_HOST_OR_IP>;DATABASE=kfar_supply;UID=sa;PWD=<YOUR_SQL_PASSWORD>;Encrypt=yes;TrustServerCertificate=yes;

# Discovery & Logs
AMA_MANIFEST_PATH=sample_data/kfar_supply/ddl/kfar_manifest.json
AMA_SQL_LOGS_GLOB=sample_data/kfar_supply/sql_logs/*.jsonl
AMA_DISCOVERY_MERGE_ALL=true

# Security & Timeouts
AMA_DB_TIMEOUT=30
AMA_ENCRYPTION_KEY=

# Optional: force live_data/ and report paths to your git clone (see docs/LIVE_CONNECTION.md)
# AMA_PROJECT_ROOT=C:\path\to\Autonomous-Migration-Architect-AMA
